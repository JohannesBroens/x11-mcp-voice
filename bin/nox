#!/usr/bin/env bash
#
# nox — CLI for the Nox voice daemon
#
# Usage:
#   nox              Start daemon + tray (if not running)
#   nox stop         Stop daemon + tray
#   nox restart      Restart daemon (tray reconnects)
#   nox status       Show current state
#   nox log          Tail the log file
#   nox chat         Open terminal chat TUI
#   nox send <text>  Send text input to daemon (skip wake word + mic)
#   nox install      Enable systemd autostart + chat window
#   nox uninstall    Disable autostart
#
set -euo pipefail

SERVICE="nox-daemon"
TRAY_SERVICE="nox-tray"
SOCKET_PATH="/run/user/$(id -u)/nox.sock"
LOG_FILE="$HOME/.local/log/nox/daemon.log"
PROJECT_DIR="$HOME/Documents/git/x11-mcp-voice"
AUTOSTART_DIR="$HOME/.config/autostart"
CHAT_DESKTOP="$AUTOSTART_DIR/nox-chat.desktop"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

_is_running() {
    systemctl --user is-active --quiet "$SERVICE" 2>/dev/null
}

_read_state() {
    if [[ -S "$SOCKET_PATH" ]]; then
        python3 -c "
import socket, json
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.settimeout(2)
s.connect('$SOCKET_PATH')
data = b''
while b'\n' not in data:
    data += s.recv(1024)
s.close()
msg = json.loads(data.decode().split('\n')[0])
print(msg.get('state', 'unknown'))
" 2>/dev/null || echo "unknown"
    else
        echo "unknown"
    fi
}

_install_chat_desktop() {
    # Generate .desktop file from template, replacing placeholders
    local bin_dir="$HOME/.local/bin"
    local icons_dir="$PROJECT_DIR/src/x11_mcp_voice/icons"
    mkdir -p "$AUTOSTART_DIR"
    sed -e "s|@BIN_DIR@|$bin_dir|g" \
        -e "s|@ICONS_DIR@|$icons_dir|g" \
        "$PROJECT_DIR/systemd/nox-chat.desktop.in" > "$CHAT_DESKTOP"
}

_remove_chat_desktop() {
    rm -f "$CHAT_DESKTOP"
}

_chat_enabled() {
    [[ -f "$CHAT_DESKTOP" ]]
}

cmd_start() {
    if _is_running; then
        state=$(_read_state)
        echo -e "${GREEN}nox:${NC} already running (${CYAN}${state}${NC})"
        return 0
    fi
    echo -e "${GREEN}nox:${NC} starting daemon..."
    systemctl --user start "$SERVICE"
    echo -e "${GREEN}nox:${NC} starting tray..."
    systemctl --user start "$TRAY_SERVICE" 2>/dev/null || true
    sleep 1
    if _is_running; then
        state=$(_read_state)
        echo -e "${GREEN}nox:${NC} running (${CYAN}${state}${NC})"
    else
        echo -e "${RED}nox:${NC} failed to start. Check: journalctl --user -u $SERVICE"
        return 1
    fi
}

cmd_stop() {
    echo -e "${GREEN}nox:${NC} stopping..."
    systemctl --user stop "$TRAY_SERVICE" 2>/dev/null || true
    systemctl --user stop "$SERVICE" 2>/dev/null || true
    echo -e "${GREEN}nox:${NC} stopped"
}

cmd_restart() {
    echo -e "${GREEN}nox:${NC} restarting daemon..."
    systemctl --user restart "$SERVICE"
    sleep 1
    if _is_running; then
        state=$(_read_state)
        echo -e "${GREEN}nox:${NC} running (${CYAN}${state}${NC})"
    else
        echo -e "${RED}nox:${NC} failed to restart"
        return 1
    fi
}

cmd_status() {
    if _is_running; then
        state=$(_read_state)
        echo -e "${GREEN}nox:${NC} running (${CYAN}${state}${NC})"
    else
        echo -e "${YELLOW}nox:${NC} not running"
    fi

    if _chat_enabled; then
        echo -e "${GREEN}nox:${NC} chat window: enabled (opens minimized on login)"
    else
        echo -e "${YELLOW}nox:${NC} chat window: disabled"
    fi
}

cmd_log() {
    if [[ -f "$LOG_FILE" ]]; then
        tail -f "$LOG_FILE"
    else
        echo -e "${YELLOW}nox:${NC} no log file at $LOG_FILE"
        echo "  Try: journalctl --user -u $SERVICE -f"
    fi
}

cmd_chat() {
    exec "$PROJECT_DIR/.venv/bin/python" -m x11_mcp_voice.chat
}

cmd_send() {
    local text="${*}"
    if [[ -z "$text" ]]; then
        echo -e "${YELLOW}nox:${NC} Usage: nox send <message>"
        return 1
    fi
    INPUT_SOCKET="/run/user/$(id -u)/nox-input.sock"
    if [[ ! -S "$INPUT_SOCKET" ]]; then
        echo -e "${RED}nox:${NC} daemon not running (no input socket)"
        return 1
    fi
    python3 -c "
import socket, sys
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.connect(sys.argv[1])
s.sendall(sys.argv[2].encode() + b'\n')
s.close()
" "$INPUT_SOCKET" "$text" 2>/dev/null
    echo -e "${GREEN}nox:${NC} sent: ${CYAN}${text}${NC}"
}

cmd_context() {
    CONTEXT_FILE="$HOME/.config/nox/user-context.txt"
    mkdir -p "$(dirname "$CONTEXT_FILE")"

    if [[ ! -f "$CONTEXT_FILE" ]]; then
        cat > "$CONTEXT_FILE" << 'TEMPLATE'
# Nox User Context
# Write anything here that Nox should know about you.
# This is injected into every interaction as context.
# Lines starting with # are ignored by Nox but kept for your reference.
#
# Examples:
#   - When I say "play music", use the YouTube Music desktop app (not the browser)
#   - My car is a 2023 Toyota RAV4 Prime
#   - I prefer English for AI interactions
#   - My name is Alex
#
TEMPLATE
        echo -e "${GREEN}nox:${NC} created $CONTEXT_FILE"
    fi

    # Open in the user's preferred editor
    exec "${EDITOR:-nano}" "$CONTEXT_FILE"
}

cmd_install() {
    SYSTEMD_DIR="$HOME/.config/systemd/user"
    BIN_DIR="$HOME/.local/bin"
    mkdir -p "$SYSTEMD_DIR" "$BIN_DIR"

    # Install systemd units
    /bin/cp "$PROJECT_DIR/systemd/nox-daemon.service" "$SYSTEMD_DIR/"
    /bin/cp "$PROJECT_DIR/systemd/nox-tray.service" "$SYSTEMD_DIR/"
    systemctl --user daemon-reload
    systemctl --user enable "$SERVICE" "$TRAY_SERVICE"

    # Install CLI + chat autostart wrapper
    /bin/cp "$PROJECT_DIR/bin/nox" "$BIN_DIR/nox"
    /bin/cp "$PROJECT_DIR/bin/nox-chat-autostart" "$BIN_DIR/nox-chat-autostart"
    chmod +x "$BIN_DIR/nox" "$BIN_DIR/nox-chat-autostart"

    # Install chat window autostart (on by default)
    # Check config for chat_autostart preference
    CHAT_AUTO=$("$PROJECT_DIR/.venv/bin/python" -c "
from x11_mcp_voice.config import load_config
c = load_config()
print('true' if c.service.chat_autostart else 'false')
" 2>/dev/null || echo "true")

    if [[ "$CHAT_AUTO" == "true" ]]; then
        _install_chat_desktop
        echo -e "${GREEN}nox:${NC} chat window enabled (opens minimized on login)"
    else
        _remove_chat_desktop
        echo -e "${YELLOW}nox:${NC} chat window disabled (set service.chat_autostart: true to enable)"
    fi

    echo -e "${GREEN}nox:${NC} installed and enabled for autostart"
    echo "  Services: $SYSTEMD_DIR/{nox-daemon,nox-tray}.service"
    echo "  CLI: $BIN_DIR/nox"
    echo "  Chat: $CHAT_DESKTOP"
    echo "  Start now with: nox"
}

cmd_uninstall() {
    systemctl --user stop "$TRAY_SERVICE" 2>/dev/null || true
    systemctl --user stop "$SERVICE" 2>/dev/null || true
    systemctl --user disable "$SERVICE" "$TRAY_SERVICE" 2>/dev/null || true
    _remove_chat_desktop
    echo -e "${GREEN}nox:${NC} disabled autostart"
}

case "${1:-}" in
    "")         cmd_start ;;
    start)      cmd_start ;;
    stop)       cmd_stop ;;
    restart)    cmd_restart ;;
    status)     cmd_status ;;
    log)        cmd_log ;;
    chat)       cmd_chat ;;
    send)       shift; cmd_send "$@" ;;
    context)    cmd_context ;;
    install)    cmd_install ;;
    uninstall)  cmd_uninstall ;;
    *)
        echo "Usage: nox [start|stop|restart|status|log|chat|send|context|install|uninstall]"
        exit 1
        ;;
esac
